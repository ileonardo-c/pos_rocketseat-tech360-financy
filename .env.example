DATABASE_URL=postgresql://financy_user:financy_password@localhost:5432/financy

# Infra / Dev stack (compose)
POSTGRES_DB=financy
POSTGRES_USER=financy_user
POSTGRES_PASSWORD=financy_password
POSTGRES_PORT=5432
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://host.docker.internal:5173

# Storage (MinIO)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=financy
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://host.docker.internal:5173,http://frontend:5173

AWS_S3_ENDPOINT_INTERNAL=http://s3.internal:9000
# Public/object URL reachable by browser for signed uploads/downloads
AWS_S3_ENDPOINT_PUBLIC=http://localhost:9000
# CSV hosts that should receive signed URLs with AWS_S3_ENDPOINT_PUBLIC
S3_PUBLIC_ORIGIN_HOSTS=localhost,127.0.0.1,host.docker.internal
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=financy
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_URL_EXPIRES_IN=900

# SMTP (password reset)
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@financy.local
RESET_CODE_TTL_SECONDS=900
RESET_CODE_MAX_ATTEMPTS=5
RESET_CODE_REQUEST_COOLDOWN_SECONDS=60
RESET_CODE_PEPPER=financy-reset-pepper
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAME_SITE=Strict
RATE_LIMIT_GLOBAL_MAX_REQUESTS=1000
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX_REQUESTS=200
RATE_LIMIT_AUTH_WINDOW_MS=60000

# E2E seed bootstrap (QA only)
E2E_SEED_NAME=Financy Admin
E2E_SEED_EMAIL=admin@financy.local
E2E_SEED_PASSWORD=TestAdmin123!
E2E_SEED_AVATAR_PATH=./frontend/tests/e2e/fixtures/seed-avatar.png
E2E_SEED_SKIP_AVATAR_SETUP=false
E2E_SEED_DRY_RUN=false
E2E_SEED_MONTH_ONLY=true
E2E_SEED_DAYS_OFFSET=0
E2E_SEED_TRANSACTIONS_PER_PAGE=50

# Frontend
VITE_BACKEND_URL=http://localhost:4000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal,frontend
