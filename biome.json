{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "correctness": { "useExhaustiveDependencies": "off" }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100,
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      "**/node_modules/**",
      "**/.pnpm-store/**",
      "**/dist/**",
      "**/.agents/**",
      "**/.tmp-run/**",
      ".github/**",
      "**/.next/**",
      "**/test-results/**",
      "**/playwright-report/**"
    ]
  }
}
