#!/usr/bin/env bash
set -euo pipefail

# Run Biome only for staged files relevant to this monorepo.
# It avoids checking the full repository on every commit.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

BIOME_FILES=$(printf "%s\n" "$STAGED_FILES" | awk '/^(backend\/|frontend\/|biome\.json|package\.json|pnpm-workspace\.yaml)/ && /\.(ts|tsx|js|jsx|json|css|md|yml|yaml)$/')

if [ -z "$BIOME_FILES" ]; then
  exit 0
fi

echo "Running Biome on staged files..."
printf "%s\n" "$BIOME_FILES"

printf "%s\n" "$BIOME_FILES" | xargs pnpm exec biome check --no-errors-on-unmatched
