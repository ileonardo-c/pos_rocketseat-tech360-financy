{
  "name": "@financy/backend",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "biome check src",
    "test:api-contract": "node tests/api/graphql-contract.test.mjs",
    "test:password-reset-service": "tsx src/features/auth/password-reset-service.test.ts",
    "test:auth-regression": "node tests/api/auth-regression.test.mjs",
    "test:env-production": "pnpm build && node tests/api/env-production.test.mjs",
    "test": "pnpm test:api-contract && pnpm test:password-reset-service && pnpm test:auth-regression && pnpm test:env-production",
    "prisma:generate": "prisma generate",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "prisma": {
    "seed": "pnpm prisma:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.5",
    "graphql": "^16.9.0",
    "jsonwebtoken": "^9.0.2",
    "mercurius": "^16.9.0",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "@prisma/engines": "5.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "^5.20.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
