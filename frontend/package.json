{
  "name": "@financy/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "check": "biome check src",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --workers=1 --grep \"@smoke-login\"",
    "test:e2e:journey": "playwright test --workers=1 --grep \"@journey-full\"",
    "test:e2e:ownership": "playwright test --workers=1 --grep \"@ownership\"",
    "test:e2e:transition": "playwright test --workers=1 --grep \"@transition\"",
    "test:e2e:contract": "playwright test --workers=1 --grep \"@smoke-dashboard\"",
    "test:e2e:visual": "playwright test --workers=1 --grep \"@visual\"",
    "test:e2e:demo-video": "playwright test --workers=1 --grep \"@demo-video-checklist\""
  },
  "dependencies": {
    "@apollo/client": "^3.12.4",
    "@fontsource-variable/martian-mono": "^5.2.7",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@playwright/test": "1.60.0",
    "@types/node": "^22.10.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
